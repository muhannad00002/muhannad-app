# ---- Zaffa payments backend configuration ----
# Copy to `.env` and fill with the real values. NEVER commit the real .env.

# Port for this backend
PORT=8787

# Where to bounce the browser back into the app after a SmartPay redirect
APP_RETURN_URL=http://localhost:8742/index.html
# This server's public base URL (used to build SmartPay redirect/cancel URLs)
PUBLIC_BASE_URL=http://localhost:8787

# ---- Bank Muscat SmartPay (from your onboarding email) ----
SMARTPAY_MERCHANT_ID=
SMARTPAY_ACCESS_CODE=
SMARTPAY_WORKING_KEY=
# Hosted transaction endpoint.
#   UAT:        https://spayuattrns.bmtest.om/transaction.do?command=initiateTransaction
#   Production: https://smartpaytrns.bankmuscat.com/transaction.do?command=initiateTransaction
SMARTPAY_TXN_URL=https://smartpaytrns.bankmuscat.com/transaction.do?command=initiateTransaction
SMARTPAY_CURRENCY=OMR

# ---- Apple In-App Purchase ----
APPLE_BUNDLE_ID=com.zaffa.app
APPLE_SHARED_SECRET=
APPLE_ENVIRONMENT=sandbox
